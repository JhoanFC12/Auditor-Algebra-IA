# Copy this file to `.env.local` (recommended) or `.env`
# and fill values for your machine. Do not commit real secrets.

# --- Required for scan pipeline (default provider: HuggingFace) ---
SCAN_PROVIDER=hf
HF_TOKEN=hf_xxx_replace_me

# --- Optional alternative provider ---
OPENAI_API_KEY=sk_replace_me
OPENAI_SCAN_MODEL=

# --- HuggingFace model/router options ---
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=Jhoan12/math-ocr-qwen2.5-vl-3b-geometry-rules-merged-v4
HF_OCR_ENSEMBLE=0
# Endpoint OpenAI-compatible dedicado para el adaptador OCR entrenado.
# HF_TRAINED_OCR_BASE_URL=https://xxxxxxxx.endpoints.huggingface.cloud/v1
# HF_MODEL=Jhoan12/math-ocr-qwen2.5-vl-3b-geometry-rules-merged-v4
# HF_TRAINED_OCR_ENDPOINT_NAME=math-ocr-geometry-rules-v4
# HF_TRAINED_OCR_CLIENT_CONCURRENCY=4
# HF_TRAINED_OCR_QUEUE_POLL_SECONDS=2
# HF_TRAINED_OCR_QUEUE_WAIT_TIMEOUT_SECONDS=14400
# HF_ENDPOINT_START_TIMEOUT=420
# HF_ENDPOINT_POLL_SECONDS=8
# HF_ENDPOINT_COLD_START_RETRIES=3

# --- External OCR API route (optional, cloud only) ---
# Nanonets DocStrange API. Get a key at https://docstrange.nanonets.com
NANONETS_API_KEY=
NANONETS_OCR_URL=https://extraction-api.nanonets.com/api/v1/extract/sync
NANONETS_OUTPUT_FORMAT=markdown

# Generic OpenAI-compatible OCR endpoint for hosted models
# such as a remote vLLM/TGI deployment of Chandra, Nanonets OCR2,
# PaddleOCR-VL, LightOnOCR, GLM-OCR, etc.
EXTERNAL_OCR_PROVIDER_NAME=
EXTERNAL_OCR_BASE_URL=
EXTERNAL_OCR_API_KEY=
EXTERNAL_OCR_MODEL=
EXTERNAL_OCR_MAX_TOKENS=3200

# --- DB profiles ---
DB_PROFILE_DEFAULT=local_mirror
DB_SHARED_NAME=mathcontentstudio

# Local mirror for fast editing
DB_LOCAL_MIRROR_HOST=127.0.0.1
DB_LOCAL_MIRROR_PORT=5432
DB_LOCAL_MIRROR_NAME=mathcontentstudio_local_mirror
DB_LOCAL_MIRROR_USER=postgres
DB_LOCAL_MIRROR_PASSWORD=postgres
DB_LOCAL_MIRROR_SSLMODE=disable

# Cloud/server profile for publish and web
DB_CLOUD_HOST=<cloud-host>
DB_CLOUD_PORT=5432
DB_CLOUD_NAME=mathcontentstudio
DB_CLOUD_USER=mathcontentstudio_app
DB_CLOUD_PASSWORD=replace_me
DB_CLOUD_SSLMODE=require
DB_CONNECT_TIMEOUT=5
# Reintentos de conexion y keepalive (recomendado para tuneles/servidor remoto)
DB_CONNECT_RETRIES=2
DB_CONNECT_RETRY_DELAY_MS=350
DB_KEEPALIVES_IDLE=30
DB_KEEPALIVES_INTERVAL=10
DB_KEEPALIVES_COUNT=5
# 0 desactiva idle_in_transaction_session_timeout (evita cortes en sync/publicacion larga)
DB_IDLE_IN_TX_TIMEOUT_MS=0
# DB_SSLROOTCERT=

# --- Transcriptor optional settings ---
TESS_LANG=spa+eng
YOLO_PROBLEM_MODEL=
YOLO_SEGMENT_MODEL=
YOLO_FIGURE_SEGMENT_MODEL=models/problem_segmentation_yolov8n_golden_v1/weights/best.pt
YOLO_FIGURE_MODEL=
YOLO_BBOX_MODEL=
YOLO_PROBLEM_MIN_CONF=0.12
FIG_DETECT_MIN_CONF=0.45
FIG_CROP_DIR=figuras_recortadas
