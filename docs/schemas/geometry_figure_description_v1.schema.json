{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditor-ia.local/schemas/geometry_figure_description_v1.schema.json",
  "title": "geometry_figure_description_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_record_id",
    "figure_tag",
    "figure_type",
    "visual_text",
    "primitives",
    "formalgeo_candidate",
    "evidence",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "geometry_figure_description_v1"
    },
    "source_record_id": {
      "type": "string",
      "minLength": 1
    },
    "figure_tag": {
      "type": "string",
      "minLength": 1
    },
    "figure_type": {
      "type": "string",
      "enum": [
        "geometria_plana",
        "geometria_espacial",
        "grafico_funcion",
        "tabla",
        "otro"
      ]
    },
    "visual_text": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "points",
        "measure_labels",
        "other_labels"
      ],
      "properties": {
        "points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "measure_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "other_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "primitives": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "points",
        "segments",
        "circles",
        "arcs"
      ],
      "properties": {
        "points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "circles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "arcs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "formalgeo_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "construction_cdl",
        "condition_cdl",
        "goal_cdl"
      ],
      "properties": {
        "construction_cdl": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "condition_cdl": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "goal_cdl": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "predicate",
          "source",
          "confidence"
        ],
        "properties": {
          "predicate": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
