{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditor-ia.local/schemas/problem_semantic_profile_v1.schema.json",
  "title": "problem_semantic_profile_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "problem_id",
    "modality",
    "course",
    "topic",
    "statement_summary",
    "concepts",
    "skills",
    "objects",
    "given_conditions",
    "unknowns",
    "representation",
    "difficulty",
    "evidence",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": "problem_semantic_profile_v1"
    },
    "problem_id": {
      "type": "string",
      "minLength": 1
    },
    "modality": {
      "type": "string",
      "enum": [
        "text_only",
        "text_image",
        "image_dominant",
        "merged_continuation"
      ]
    },
    "course": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "subtopic": {
      "type": "string",
      "default": ""
    },
    "statement_summary": {
      "type": "string",
      "minLength": 1
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "objects": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "required": [
        "geometry",
        "algebra",
        "arithmetic"
      ],
      "properties": {
        "geometry": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "algebra": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "arithmetic": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "given_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "representation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "embedding_text",
        "search_keywords",
        "canonical_problem_type"
      ],
      "properties": {
        "embedding_text": {
          "type": "string",
          "minLength": 1
        },
        "search_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "canonical_problem_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimated_level",
        "scale",
        "signals",
        "reason"
      ],
      "properties": {
        "estimated_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "scale": {
          "const": "1-5"
        },
        "signals": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "steps_estimated",
            "requires_graph_reading",
            "requires_formula_memory",
            "requires_multi_case_reasoning",
            "requires_algebraic_manipulation"
          ],
          "properties": {
            "steps_estimated": {
              "type": "integer",
              "minimum": 0
            },
            "requires_graph_reading": {
              "type": "boolean"
            },
            "requires_formula_memory": {
              "type": "boolean"
            },
            "requires_multi_case_reasoning": {
              "type": "boolean"
            },
            "requires_algebraic_manipulation": {
              "type": "string",
              "enum": [
                "none",
                "low",
                "medium",
                "high"
              ]
            }
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "uses_text",
        "uses_figure",
        "figure_tags",
        "source_fields"
      ],
      "properties": {
        "uses_text": {
          "type": "boolean"
        },
        "uses_figure": {
          "type": "boolean"
        },
        "figure_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "source_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "human_verified",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "sin_revisar",
            "revisado",
            "requiere_correccion"
          ]
        },
        "human_verified": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
