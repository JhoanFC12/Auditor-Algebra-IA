# Copy this file to `.env.local` (recommended) or `.env`
# and fill values for your machine. Do not commit real secrets.

# --- Required for scan pipeline (default provider: HuggingFace) ---
SCAN_PROVIDER=hf
HF_TOKEN=hf_xxx_replace_me

# --- Optional alternative provider ---
OPENAI_API_KEY=sk_replace_me
OPENAI_SCAN_MODEL=

# --- HuggingFace model/router options ---
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=Jhoan12/math-ocr-qwen2.5-vl-3b-geometry-rules-merged-v4
HF_OCR_ENSEMBLE=0

# --- DB connection (used by DB modules) ---
# `DB_*` are the active connection values used by the app.
# `DB_SHARED_NAME` is the common logical DB name.
# You can define `DB_CLOUD_*` in `.env.local` to override the cloud profile explicitly.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mathcontentstudio
DB_SHARED_NAME=mathcontentstudio
DB_USER=postgres
DB_PASSWORD=replace_me
DB_SSLMODE=disable

# Optional explicit cloud profile (e.g. Neon)
# DB_CLOUD_HOST=ep-xxxxxxx.region.aws.neon.tech
# DB_CLOUD_PORT=5432
# DB_CLOUD_USER=your_neon_user
# DB_CLOUD_PASSWORD=your_neon_password
# DB_CLOUD_SSLMODE=require
# DB_CLOUD_SSLROOTCERT=

# --- Transcriptor optional settings ---
TESS_LANG=spa+eng
YOLO_PROBLEM_MODEL=
YOLO_SEGMENT_MODEL=
YOLO_FIGURE_SEGMENT_MODEL=E:\Github\Auditor-IA\models\problem_segmentation_yolov8n_golden_v1\weights\best.pt
YOLO_FIGURE_MODEL=
YOLO_BBOX_MODEL=
YOLO_PROBLEM_MIN_CONF=0.12
FIG_DETECT_MIN_CONF=0.45
FIG_CROP_DIR=figuras_recortadas
